
mov reg/mem to/from register        100010dw, mod reg r/m
mov imm     to      register/mem    1100011w, mod 000 r/m,  data,           data if w = 1
mov imm     to      register        1011wreg, data,         data if w = 1
mov mem     to      acc             1010000w, addr-low,     addr-high
mov acc     to      mem             1010001w, addr-low,     addr-high
mov reg/mem to      seg             10001110, mod 0 reg r/m
mov seg     to      reg/mem         10001100, mod 0 reg r/m

push reg    01010reg

inc reg     01000reg
dec reg     01001reg

xor reg     to      reg             0011000w, 11regreg

cmp reg/mem with    reg             0011101w, mod reg r/m
cmp reg     with    reg/mem         0011100w, mod reg r/m
cmp imm     with    reg/mem         100000sw, mod 111 r/m,  data,           data if s w = 01
cmp acc     with    imm             0011110w, data,         data if w = 1

clc 0xf8
stc 0xf9
