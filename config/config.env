config = debug
# debug or release
arch = x86_64
imageType = disk
imageFS = fat32
imageSize = 250m
toolchain = ../.toolchains
enable_paging = true
max_path_length = 512

# Mount methods:
# guestfs - uses libguestfs, doesn't require admin rights but may not work on some systems
# mount - uses mount, requires sudo
mountMethod = mount