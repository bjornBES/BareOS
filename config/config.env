config = debug
# debug or release

target = 64
arch = x86_64
imageType = disk
imageFS = fat32
imageSize = 250m
toolchain = ../.toolchains
enable_paging = true
max_path_length = 512

# Mount methods:
# guestfs - uses libguestfs, doesn't require admin rights but may not work on some systems
# mount - uses mount, requires sudo
mountMethod = mount

enable_multi_core = 1

# kernel

## vmm
use_eager_fork = 0

## include BSW
Include_BSW = 1
