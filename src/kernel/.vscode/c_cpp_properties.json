{
    "configurations": [
        {
            "name": "GCC",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/../../toolchain/gcc-build-11.2.0/gcc/include/",
                "${workspaceFolder}/../libs",
                "${workspaceFolder}/../libs/arch/x86",
                "${workspaceFolder}/../kernel",
